generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Person {
  id         Int      @id @default(autoincrement())
  name       String   @unique @db.VarChar(200)
  isDirector Boolean  @default(false) @map("is_director")
  isActor    Boolean  @default(false) @map("is_actor")

  moviesDirected MovieDirector[]
  castCredits    MovieCast[]

  @@map("people")
  @@index([isDirector], map: "idx_people_director")
  @@index([isActor], map: "idx_people_actor")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  role      String   @default("USER") @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")

  reviews   Review[]
  movies    UserMovie[]

  @@map("users")
}

model Genre {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(100)

  movies MovieGenre[]

  @@map("genres")
}

model Movie {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(300)
  year        Int?      @db.SmallInt
  runtimeMin  Int?      @map("runtime_min") @db.SmallInt
  imdbRating  Decimal?  @map("imdb_rating") @db.Decimal(3, 1)
  overview    String?   @db.Text
  posterUrl   String?   @map("poster_url") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")

  directors MovieDirector[]
  cast      MovieCast[]
  genres    MovieGenre[]
  reviews   Review[]
  userMovies UserMovie[]

  @@map("movies")
  @@index([year], map: "idx_year")
  @@index([imdbRating], map: "idx_rating")
}

model Review {
  id        Int      @id @default(autoincrement())
  movieId   Int      @map("movie_id")
  userId    Int      @map("user_id")
  rating    Int      @db.SmallInt
  comment   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
  @@index([movieId], map: "idx_review_movie")
  @@index([userId], map: "idx_review_user")
}

model UserMovie {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  movieId   Int      @map("movie_id")
  listType  String   @map("list_type") @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId, listType])
  @@map("user_movies")
  @@index([userId, listType], map: "idx_user_movies_list")
}

model MovieDirector {
  movieId  Int @map("movie_id")
  personId Int @map("person_id")

  movie  Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([movieId, personId])
  @@map("movie_directors")
}

model MovieCast {
  movieId      Int @map("movie_id")
  personId     Int @map("person_id")
  billingOrder Int @default(1) @map("billing_order") @db.SmallInt

  movie  Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([movieId, personId])
  @@index([personId], map: "idx_cast_person")
  @@map("movie_cast")
}

model MovieGenre {
  movieId Int @map("movie_id")
  genreId Int @map("genre_id")

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
  @@map("movie_genres")
}
